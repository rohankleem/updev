_ignore*
.env
composer.lock
vendor/*
.vscode
public_html/wp-content/uploads
*.log
public_html/wp-content/themes/buildio2/node_modules
public_html/wp-content/themes/buildio2/dist/*.bundle.*

# Exclude all WordPress plugins from git — only unipixel (the plugin we develop) is tracked
public_html/wp-content/plugins/*
!public_html/wp-content/plugins/index.php
!public_html/wp-content/plugins/unipixel
!public_html/wp-content/plugins/unipixel/**
